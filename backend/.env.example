# Scraper Agent Backend - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# At least one LLM provider API key is required
# Set LLM_PROVIDER to choose the default provider: "claude", "ollama", "cohere", "huggingface"
LLM_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Cohere (also used for embeddings)
COHERE_API_KEY=

# HuggingFace
HUGGINGFACE_API_KEY=

# Ollama (local or cloud)
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=kimi-k2:1t-cloud

# =============================================================================
# SUPABASE AUTHENTICATION
# =============================================================================

# Get these from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Get this from: Supabase Dashboard -> Project Settings -> API -> JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

HOST=0.0.0.0
PORT=8000
DEBUG=false

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:7860

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute for expensive endpoints (e.g., scraping)
RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# STORAGE
# =============================================================================

# Base path for storing scraped data and session files
STORAGE_BASE_PATH=./data

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Maximum parallel extraction tasks
MAX_PARALLEL_EXTRACTIONS=3

# Default timeout for operations (seconds)
DEFAULT_TIMEOUT=30

# Playwright browser page load timeout (seconds)
BROWSER_TIMEOUT=60
